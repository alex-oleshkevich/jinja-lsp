{
  "name": "jinja-lsp",
  "displayName": "Jinja LSP",
  "description": "Jinja2 template language support via jinja-lsp",
  "version": "0.1.0",
  "publisher": "alex-oleshkevich",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "repository": {
    "type": "git",
    "url": "https://github.com/alex-oleshkevich/jinja-lsp"
  },
  "activationEvents": [
    "onLanguage:jinja",
    "onLanguage:jinja-html",
    "workspaceContains:jinja.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "jinja",
        "aliases": ["Jinja", "jinja"],
        "extensions": [".jinja", ".jinja2", ".j2"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "jinja-html",
        "aliases": ["Jinja HTML", "jinja-html"],
        "extensions": [".html"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jinja",
        "scopeName": "source.jinja",
        "path": "./syntaxes/jinja.tmLanguage.json"
      },
      {
        "language": "jinja-html",
        "scopeName": "text.html.jinja",
        "path": "./syntaxes/jinja-html.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Jinja LSP",
      "properties": {
        "jinja-lsp.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the jinja-lsp binary. Leave empty to find jinja-lsp on PATH."
        },
        "jinja-lsp.templates": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["..."],
          "description": "Template directories to scan. Use '...' for auto-discovery."
        },
        "jinja-lsp.extensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["html", "jinja", "jinja2", "j2"],
          "description": "File extensions to treat as Jinja templates."
        },
        "jinja-lsp.extras": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["flask", "starlette", "starlette-babel", "starlette-flash"]
          },
          "default": [],
          "description": "Extension packs to activate (framework-specific builtins)."
        },
        "jinja-lsp.customBuiltins": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Directories of custom built-in documentation files."
        },
        "jinja-lsp.hints": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Directories holding user hint files."
        },
        "jinja-lsp.lint.select": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Diagnostic codes or class prefixes to enable (e.g. JINJA-E1)."
        },
        "jinja-lsp.lint.ignore": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Diagnostic codes or class prefixes to suppress."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "tsc -p ./",
    "test": "node --test out/*.test.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
